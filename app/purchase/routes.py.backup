@purchase.route('/purchase_payment/save', methods=['POST'])
@login_required
def save_purchase_payment():
    try:
        data = request.get_json()
        conn = get_db_connection()
        cursor = conn.cursor()
        
        # 지급 정보 저장
        cursor.execute("""
            INSERT INTO dbo.purchase_payment (
                purchase_no, payment_date, payment_method,
                amount, vat, -- Removed transfer_fee
                remarks,
                createuser, createdate
            ) VALUES (?, ?, ?, ?, ?, ?, ?, GETDATE())
        """, (
            data['purchaseNo'],
            data['paymentDate'],
            data['paymentMethod'],
            data['amount'],
            data.get('vat', 0),  # 부가세
            # data.get('transferFee', 0),  # Removed 이체수수료
            data.get('remarks', ''),
            'SYSTEM'
        ))
        
        # 매입 상태 업데이트 (지급완료 여부 확인)
        cursor.execute("""
            WITH PaymentSum AS (
                SELECT purchase_no, SUM(amount) as total_paid
                FROM dbo.purchase_payment
                WHERE purchase_no = ?
                GROUP BY purchase_no
            )
            UPDATE dbo.purchase_master SET
                status = CASE 
                    WHEN p.total_amount <= ps.total_paid THEN 'COMPLETED'
                    ELSE 'CONFIRMED'
                END
            FROM dbo.purchase_master p
            JOIN PaymentSum ps ON p.purchase_no = ps.purchase_no
            WHERE p.purchase_no = ?
        """, (data['purchaseNo'], data['purchaseNo']))
        
        conn.commit()
        return jsonify({'success': True})
        
    except Exception as e:
        if 'conn' in locals():
            conn.rollback()
        print('Error in save_purchase_payment:', str(e))
        return jsonify({'error': str(e)}), 500
    finally:
        if 'conn' in locals():
            conn.close()

@purchase.route('/purchase_payment/detail/<purchase_no>')
@login_required
def get_purchase_payment_detail(purchase_no):
    try:
        conn = get_db_connection()
        cursor = conn.cursor()
        
        # 매입 정보 조회
        cursor.execute("""
            SELECT 
                p.*,
                v.vd_name as vendor_name,
                COALESCE(pp.total_paid, 0) as paid_amount,
                COALESCE(pp.total_vat, 0) as total_vat
                -- Removed COALESCE(pp.total_transfer_fee, 0) as total_transfer_fee
            FROM dbo.purchase_master p
            LEFT JOIN dbo.CODE_VENDOR v ON p.vendor_code = v.vd_code
            LEFT JOIN (
                SELECT 
                    purchase_no, 
                    SUM(amount) as total_paid,
                    SUM(vat) as total_vat
                    -- Removed SUM(transfer_fee) as total_transfer_fee
                FROM dbo.purchase_payment
                GROUP BY purchase_no
            ) pp ON p.purchase_no = pp.purchase_no
            WHERE p.purchase_no = ?
        """, (purchase_no,))
        
        purchase = cursor.fetchone()
        if not purchase:
            return jsonify({'error': 'Purchase not found'}), 404
            
        # 지급 이력 조회
        cursor.execute("""
            SELECT *
            FROM dbo.purchase_payment
            WHERE purchase_no = ?
            ORDER BY payment_date DESC
        """, (purchase_no,))
        
        payments = cursor.fetchall()
        
        result = {
            'purchase': {
                'purchaseNo': purchase.purchase_no,
                'purchaseDate': purchase.purchase_date.strftime('%Y-%m-%d'),
                'vendorCode': purchase.vendor_code.strip() if purchase.vendor_code else '',
                'vendorName': purchase.vendor_name.strip() if purchase.vendor_name else '',
                'totalAmount': float(purchase.total_amount) if purchase.total_amount else 0,
                'paidAmount': float(purchase.paid_amount) if purchase.paid_amount else 0,
                'totalVat': float(purchase.total_vat) if purchase.total_vat else 0,
                'remainingAmount': float(purchase.total_amount - purchase.paid_amount) if purchase.total_amount and purchase.paid_amount else float(purchase.total_amount),
                'paymentDueDate': purchase.payment_due_date.strftime('%Y-%m-%d') if purchase.payment_due_date else None,
                'status': '완료' if purchase.total_amount <= purchase.paid_amount else '미완료'
            },
            'payments': [{
                'paymentId': payment.payment_id,
                'paymentDate': payment.payment_date.strftime('%Y-%m-%d'),
                'paymentMethod': payment.payment_method.strip() if payment.payment_method else '',
                'amount': float(payment.amount) if payment.amount else 0,
                'vat': float(payment.vat) if payment.vat else 0,
                # Removed 'transferFee': float(payment.transfer_fee) if payment.transfer_fee else 0,
                'remarks': payment.remarks.strip() if payment.remarks else ''
            } for payment in payments]
        }
        
        return jsonify(result)
        
    except Exception as e:
        print('Error in get_purchase_payment_detail:', str(e))
        return jsonify({'error': str(e)}), 500
    finally:
        if 'conn' in locals():
            conn.close()

@purchase.route('/api/payment/summary', methods=['POST'], endpoint='get_purchase_payment_summary_api')
@login_required
def get_purchase_payment_summary():
    try:
        data = request.get_json()
        start_date = data.get('startDate')
        end_date = data.get('endDate')
        vendor_code = data.get('vendorCode')
        
        conn = get_db_connection()
        cursor = conn.cursor()
        
        # 기본 쿼리
        query = """
            SELECT 
                v.vd_code as vendor_code,
                v.vd_name as vendor_name,
                p.purchase_date,
                p.currency_code,
                p.exchange_rate,
                p.total_amount,
                p.total_amount * 0.07 as vat_amount,
                p.total_amount * 1.07 as sum_amount,
                COALESCE(pp.paid_amount, 0) as paid_amount
            FROM dbo.purchase_master p
            LEFT JOIN dbo.CODE_VENDOR v ON p.vendor_code = v.vd_code
            LEFT JOIN (
                SELECT 
                    purchase_no, 
                    SUM(amount) as paid_amount
                FROM dbo.purchase_payment
                GROUP BY purchase_no
            ) pp ON p.purchase_no = pp.purchase_no
            WHERE 1=1
        """
        params = []
        
        # 검색 조건 추가
        if start_date:
            query += " AND p.purchase_date >= ?"
            params.append(start_date)
        if end_date:
            query += " AND p.purchase_date <= ?"
            params.append(end_date)
        if vendor_code:
            query += " AND p.vendor_code = ?"
            params.append(vendor_code)
        
        # 정렬
        query += " ORDER BY p.purchase_date DESC, v.vd_code"

        cursor.execute(query, params)
        rows = cursor.fetchall()

        items = []
        for row in rows:
            payment_date = row.purchase_date.strftime('%Y-%m-%d') if row.purchase_date else None
            
            items.append({
                'vendorName': row.vendor_name.strip() if row.vendor_name else '',
                'paymentDate': payment_date,
                'currency': row.currency_code.strip() if row.currency_code else '',
                'exchangeRate': float(row.exchange_rate) if row.exchange_rate else 0,
                'totalAmount': float(row.total_amount) if row.total_amount else 0,
                'vatAmount': float(row.vat_amount) if row.vat_amount else 0,
                'sumAmount': float(row.sum_amount) if row.sum_amount else 0,
                'paidAmount': float(row.paid_amount) if row.paid_amount else 0,
                'paidVat': float(row.paid_vat) if row.paid_vat else 0,
                'remainingAmount': float(row.total_amount - row.paid_amount) if row.total_amount and row.paid_amount else float(row.total_amount),
                'paymentDueDate': row.payment_due_date.strftime('%Y-%m-%d') if row.payment_due_date else None,
                'purchaseStatus': row.status.strip() if row.status else 'PROCESS',  # 기본값을 PROCESS로 설정
                'paymentStatus': payment_status
            })

        # Calculate summary totals
        summary = {
            'totalAmount': round(sum(item['totalAmount'] for item in result), 5),
            'totalVat': round(sum(item['totalVat'] for item in result), 5),
            'sumAmount': round(sum(item['sumAmount'] for item in result), 5),  # 총합계금액
            'paidAmount': round(sum(item['paidAmount'] for item in result), 5),  # 총지급액
            'totalPaid': round(sum(item['paidAmount'] for item in result), 5),  # 기존 totalPaid(호환)
            'totalPaidVat': round(sum(item['paidVat'] for item in result), 5),
            'remainingAmount': round(sum(item['remainingAmount'] for item in result), 5)
        }

        return jsonify({
            'payments': result,
            'pagination': {
                'totalCount': total_count,
                'currentPage': page,
                'perPage': per_page,
                'totalPages': (total_count + per_page - 1) // per_page
            },
            'summary': summary
        })

    except Exception as e:
        print(f"Error in get_purchase_payments: {str(e)}")
        raise

