                'paymentDate': payment.payment_date.strftime('%Y-%m-%d'),
                'paymentMethod': payment.payment_method.strip() if payment.payment_method else '',
                'amount': float(payment.amount) if payment.amount else 0,
                'vat': float(payment.vat) if payment.vat else 0,
                # Removed 'transferFee': float(payment.transfer_fee) if payment.transfer_fee else 0,
                'remarks': payment.remarks.strip() if payment.remarks else ''
            } for payment in payments]
        }
        
        return jsonify(result)
        
    except Exception as e:
        print('Error in get_purchase_payment_detail:', str(e))
        return jsonify({'error': str(e)}), 500
    finally:
        if 'conn' in locals():
            conn.close()

# vendors API 추가
@purchase.route('/vendors')
@login_required
def get_vendors():
    try:
        with get_db_connection() as conn:
            cursor = conn.cursor()
            cursor.execute("SELECT vd_code, vd_name FROM CODE_VENDOR WHERE usage = 'Y' ORDER BY vd_name")
            rows = cursor.fetchall()
            vendors = []
            for row in rows:
                vendors.append({
                    "code": row.vd_code.strip() if row.vd_code else "",
                    "name": row.vd_name.strip() if row.vd_name else ""
                })
            cursor.close()
            return jsonify(vendors)
    except Exception as e:
        return jsonify({"error": str(e)}), 500

# purchases API 추가 (검색 기능 포함)
@purchase.route('/purchases')
@login_required
def get_purchases():
    try:
        start_date = request.args.get('startDate', '')
        end_date = request.args.get('endDate', '')
        vendor_code = request.args.get('vendorCode', '')
        status = request.args.get('status', '')
        
        with get_db_connection() as conn:
            cursor = conn.cursor()
            
            query = """
                SELECT p.id, p.purchase_date, p.purchase_no, p.vendor_code, 
                       v.vd_name as vendor_name, p.warehouse_code, 
                       p.currency_code, p.exchange_rate, p.total_amount,
                       p.vat, p.sum_amount, p.paid_amount, p.unpaid_amount,
                       p.payment_method, p.payment_due_date, p.status
                FROM purchase_master p
                LEFT JOIN CODE_VENDOR v ON p.vendor_code = v.vd_code
                WHERE 1=1
            """
            params = []
            
            if start_date:
                query += " AND p.purchase_date >= ?"
                params.append(start_date)
            if end_date:
                query += " AND p.purchase_date <= ?"
                params.append(end_date)
            if vendor_code:
                query += " AND p.vendor_code = ?"
                params.append(vendor_code)
            if status:
                query += " AND p.status = ?"
                params.append(status)
            
            query += " ORDER BY p.purchase_date DESC, p.purchase_no DESC"
            
            cursor.execute(query, params)
            rows = cursor.fetchall()
            purchases = []
            for row in rows:
                purchases.append({
                    "id": row.id,
                    "purchase_date": str(row.purchase_date) if row.purchase_date else "",
                    "purchase_no": row.purchase_no if row.purchase_no else "",
                    "vendor_code": row.vendor_code if row.vendor_code else "",
                    "vendor_name": row.vendor_name if row.vendor_name else "",
                    "warehouse_code": row.warehouse_code if row.warehouse_code else "",
                    "currency_code": row.currency_code if row.currency_code else "",
                    "exchange_rate": float(row.exchange_rate) if row.exchange_rate else 1.0,
                    "total_amount": float(row.total_amount) if row.total_amount else 0,
                    "vat": float(row.vat) if row.vat else 0,
                    "sum_amount": float(row.sum_amount) if row.sum_amount else 0,
                    "paid_amount": float(row.paid_amount) if row.paid_amount else 0,
                    "unpaid_amount": float(row.unpaid_amount) if row.unpaid_amount else 0,
                    "payment_method": row.payment_method if row.payment_method else "",
                    "payment_due_date": str(row.payment_due_date) if row.payment_due_date else "",
                    "status": row.status if row.status else "진행중"
                })
            cursor.close()
            return jsonify(purchases)
    except Exception as e:
        from flask import current_app
        current_app.logger.error(f"Error in get_purchases: {str(e)}")
        return jsonify({"error": str(e)}), 500
    finally:
        if 'conn' in locals():
            conn.close()
